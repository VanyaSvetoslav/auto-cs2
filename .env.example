# Copy to `.env` and fill in your key. `python main.py` will load it
# automatically on startup. The real `.env` is gitignored.
#
# Get a free Steam Web API key at: https://steamcommunity.com/dev/apikey
STEAM_API_KEY=

# Bind interface (default 0.0.0.0 — all interfaces).
# Use 127.0.0.1 to restrict the server to localhost only.
# HOST=127.0.0.1

# Bind port (default 8080). Override if 8080 is already taken.
# PORT=8090
